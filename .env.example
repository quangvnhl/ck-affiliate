# Database - Neon Tech PostgreSQL
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (Auth.js v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-key-min-32-chars
AUTH_TRUST_HOST=true

# Shopee Affiliate API (sẽ cần khi implement)
# SHOPEE_APP_ID=your-shopee-app-id
# SHOPEE_API_KEY=your-shopee-api-key
# SHOPEE_API_SECRET=your-shopee-api-secret

# TikTok Affiliate API (sẽ cần khi implement)
# TIKTOK_APP_ID=your-tiktok-app-id
# TIKTOK_API_KEY=your-tiktok-api-key
# TIKTOK_API_SECRET=your-tiktok-api-secret

# Cron Job Security
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-key
